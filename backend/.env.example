# ─────────────────────────────────────────────────────────────
# TravelSync Pro — Environment Configuration
# Copy this file to .env and fill in your API keys
# ─────────────────────────────────────────────────────────────

# Flask
FLASK_SECRET_KEY=change-this-to-a-random-32-char-string-in-production
PORT=3399
DEBUG=False

# ── Google AI ─────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Google Maps Platform ──────────────────────────────────────
# Enable: Maps JavaScript, Directions, Distance Matrix, Places, Geocoding
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# ── Google Cloud Vision (OCR for receipts) ────────────────────
# Can reuse GOOGLE_MAPS_API_KEY if both enabled on same key
GOOGLE_VISION_API_KEY=

# ── Amadeus Travel API (Flights + Hotels) ─────────────────────
# Free sandbox: https://developers.amadeus.com/register
# Production: upgrade after testing
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test
# AMADEUS_ENV=production

# ── OpenWeatherMap (Weather Forecasts) ────────────────────────
# Free tier: 1000 calls/day — https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── Currency Exchange ─────────────────────────────────────────
# Open Exchange Rates: https://openexchangerates.org (free: 1000 req/month)
OPEN_EXCHANGE_APP_ID=
# Alternative: Fixer.io
FIXER_API_KEY=

# ── Zoho CRM ──────────────────────────────────────────────────
# Setup OAuth app at: https://api-console.zoho.in
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCESS_TOKEN=
ZOHO_ORG_ID=

# ── Google Cloud Storage (for uploaded documents) ─────────────
# Replaces local /static/uploads/ in production
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Database ──────────────────────────────────────────────────
# Leave empty to use SQLite (development)
# Set for Cloud SQL PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

# ── Google Cloud (Deployment) ─────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=asia-south1
