# ══════════════════════════════════════════════════════════════
#  TravelSync Pro — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Claude / AI tooling ───────────────────────────────────────
.claude/
CLAUDE.md

# ── Secrets & Environment ─────────────────────────────────────
# Block ALL .env files anywhere in the tree — keep only .env.example
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.Python
build/
dist/
.eggs/

# ── Virtual environments ──────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Database ──────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ── Uploaded files ────────────────────────────────────────────
backend/static/uploads/*
!backend/static/uploads/.gitkeep

# ── React / Node ──────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── GCP / Cloud credentials ───────────────────────────────────
*.json.key
service-account*.json
gcp-credentials*.json
application_default_credentials.json
.gcloud/

# ── IDEs & OS ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Testing ───────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
